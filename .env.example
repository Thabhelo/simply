# Web app (Vite) — copy to .env for local dev
VITE_API_BASE=http://localhost:8787
VITE_WEB_BASE=http://localhost:5173

# Contact form (EmailJS)
VITE_EMAILJS_SERVICE_ID=service_of0z8is
VITE_EMAILJS_TEMPLATE_ID=simply_contact_page
VITE_EMAILJS_PUBLIC_KEY=

# Chrome Extension (published on Chrome Web Store)
# After publishing, add your extension ID and store URL
# See docs/CHROME_EXTENSION_OAUTH_SETUP.md for OAuth redirect configuration
VITE_CHROME_EXTENSION_ID=
VITE_CHROME_STORE_URL=https://chromewebstore.google.com/detail/simply/<your-extension-id>
