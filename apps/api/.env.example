# Copy to apps/api/.env for local development (never commit real values).

# Required for full AI lesson generation (Google AI Studio → API key)
GEMINI_API_KEY=

# Optional: comma-separated fallback keys — API rotates to the next key on quota / 429
# GEMINI_API_KEYS=key_one,key_two,key_three

# Text model for detect + teach (default: gemini-2.5-pro; auto-falls back to flash on quota)
# GEMINI_MODEL=gemini-2.5-pro

# Firebase Admin SDK — pick ONE:
# Local dev (recommended):
FIREBASE_SERVICE_ACCOUNT_PATH=/Users/you/secrets/simply-firebase.json
# Cloud Run / CI (base64 of the service account JSON):
# FIREBASE_SERVICE_ACCOUNT_B64=

# Optional: UI decoration only (/library page). Not used in lesson illustrations.
PEXELS_API_KEY=

# Optional: force open mode even when Firebase creds are present
# AUTH_REQUIRED=false

# Contact form (Resend) — https://resend.com/api-keys
RESEND_API_KEY=
# Where contact submissions are delivered (default: thabhelo.duve@talladega.edu)
# CONTACT_TO_EMAIL=thabhelo.duve@talladega.edu
# Sender — use onboarding@resend.dev for testing, or a verified domain in production
# CONTACT_FROM_EMAIL=Simply <onboarding@resend.dev>

# Optional: API port (default 8787 locally, 8080 on Cloud Run)
# PORT=8787
