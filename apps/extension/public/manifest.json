{
  "manifest_version": 3,
  "name": "unfog",
  "description": "Turn dense research papers into prerequisite math guides.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unfog this paper"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8787/*", "https://arxiv.org/*"],
  "content_scripts": [
    {
      "matches": ["https://arxiv.org/*", "https://*.arxiv.org/*"],
      "js": ["content.js"]
    }
  ]
}
