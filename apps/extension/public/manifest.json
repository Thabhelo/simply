{
  "manifest_version": 3,
  "name": "Simply",
  "description": "Turn dense research papers into calm prerequisite guides.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simply explain this paper"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8787/*", "http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
