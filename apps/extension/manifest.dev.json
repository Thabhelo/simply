{
  "manifest_version": 3,
  "key": "",
  "name": "Simply",
  "description": "Turn dense research papers into calm prerequisite guides.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simply explain this paper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "identity", "storage"],
  "host_permissions": [
    "https://simply-api-k7ux27sa4q-uc.a.run.app/*",
    "http://localhost:8787/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://arxiv.org/*",
        "*://*.arxiv.org/*",
        "*://openreview.net/*",
        "*://*.openreview.net/*",
        "*://biorxiv.org/*",
        "*://*.biorxiv.org/*",
        "*://medrxiv.org/*",
        "*://*.medrxiv.org/*",
        "*://ssrn.com/*",
        "*://*.ssrn.com/*",
        "*://aclanthology.org/*",
        "*://*.aclanthology.org/*",
        "*://proceedings.mlr.press/*",
        "*://*.proceedings.mlr.press/*",
        "*://papers.nips.cc/*",
        "*://*.papers.nips.cc/*",
        "*://neurips.cc/*",
        "*://*.neurips.cc/*",
        "*://ieee.org/*",
        "*://*.ieee.org/*",
        "*://springer.com/*",
        "*://*.springer.com/*",
        "*://sciencedirect.com/*",
        "*://*.sciencedirect.com/*",
        "*://nature.com/*",
        "*://*.nature.com/*",
        "*://science.org/*",
        "*://*.science.org/*",
        "*://frontiersin.org/*",
        "*://*.frontiersin.org/*",
        "*://plos.org/*",
        "*://*.plos.org/*",
        "file:///*/*.pdf"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
