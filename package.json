{
  "name": "simply",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/extension"
  ],
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"npm run dev --workspace apps/api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:extension": "npm run dev --workspace apps/extension",
    "build": "tsc -b && vite build && npm run build --workspaces",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
