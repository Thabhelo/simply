{
  "name": "simply",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/extension"
  ],
  "scripts": {
    "predev": "bash scripts/free-port.sh 5173",
    "dev": "concurrently \"vite --host 0.0.0.0 --port 5173 --strictPort\" \"npm run dev --workspace apps/api\"",
    "dev:web": "npm run predev && vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:extension": "npm run dev --workspace apps/extension",
    "build": "tsc -b && vite build && npm run build --workspaces",
    "build:web": "tsc -b && vite build",
    "package:extension": "./scripts/package-extension.sh",
    "lint": "eslint .",
    "test": "npm run test --workspace apps/api",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "firebase": "^12.15.0",
    "framer-motion": "^12.40.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
